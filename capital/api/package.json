    "@types/passport": "^1.0.17",
    "axios": "^1.14.0",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.6.0",
