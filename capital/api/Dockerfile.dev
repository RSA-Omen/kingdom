FROM node:20-alpine

WORKDIR /app

# Install Python and pip for Python dependency scanning
RUN apk add --no-cache python3 py3-pip python3-dev gcc musl-dev && \
    pip3 install --break-system-packages --upgrade pip && \
    pip3 install --break-system-packages pip-audit

# Copy package files
COPY package*.json ./

# Install dependencies (including dev dependencies for tsx)
RUN npm install

# Expose port
EXPOSE 5000

# Start dev server (code will be mounted as volume)
CMD ["npm", "run", "dev"]

