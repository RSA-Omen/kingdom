# Capital API — environment configuration
# Copy to .env and fill in values. Never commit the .env file.

# Admin auth (basic fallback)
ADMIN_PASSWORD=

# Database (SQLite)
DB_PATH=../data/app-registry.db

# Docker socket (for container management routes)
DOCKER_SOCKET=/var/run/docker.sock

# Health check polling interval (ms)
HEALTH_CHECK_INTERVAL=300000

# Azure AD SSO
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:5000/api/auth/callback
AZURE_FRONTEND_REDIRECT_URI=http://localhost:3000

# Optional integrations
GROQ_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GRAYLOG_URL=http://gvdi-30.gekkosystems.local:19000
GRAYLOG_USER=
GRAYLOG_PASSWORD=
GKGPU_HEALTH_URL=http://192.168.0.59:11434/api/tags
